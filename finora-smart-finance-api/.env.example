# .env.example (TEMPLATE — KEINE SECRETS EINTRAGEN!)
# Kopiere diese Datei nach .env und fülle die Werte aus.

# ============================================
# SERVER
# ============================================
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb+srv://<your-user>:<your-password>@<your-cluster>.mongodb.net/finora?retryWrites=true&w=majority
MONGODB_DB=finora

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173

# ============================================
# JWT (Authentication)
# ============================================
JWT_SECRET=your-secret-key-min-32-chars-change-in-production
JWT_EXPIRE=7d
JWT_ACCESS_EXPIRE=3600
JWT_REFRESH_EXPIRE=604800

# ============================================
# ADMIN API
# ============================================
ADMIN_API_KEY=your-admin-api-key-min-32-chars

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_AGE_DAYS=14
LOG_MAX_SIZE_MB=10

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_STATS=true
FEATURE_BULK_DELETE=true
ENABLE_REPORT_SCHEDULER=false

# ============================================
# SMTP (Email-Versand)
# ============================================
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=finora@yellowdeveloper.de
SMTP_PASS=your-smtp-password
SMTP_FROM="Finora" <finora@yellowdeveloper.de>

# ============================================
# CONTACT EMAIL
# ============================================
CONTACT_EMAIL=finora@yellowdeveloper.de
